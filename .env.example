# Server
PORT=3000
NODE_ENV=development

# Bridge.xyz (sandbox) — USD <-> USDC orchestration
BRIDGE_API_KEY=your_bridge_sandbox_api_key_here
BRIDGE_API_BASE_URL=https://api.sandbox.bridge.xyz

# Local African off-ramp provider (e.g. local payout/disbursement partner)
OFFRAMP_API_KEY=your_local_offramp_api_key_here
OFFRAMP_API_BASE_URL=https://sandbox.local-offramp-provider.com
